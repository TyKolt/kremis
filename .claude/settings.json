{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "english",
  "outputStyle": "Explanatory",
  "env": {
    "DISABLE_TELEMETRY": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "LSP",
      "Grep",
      "Glob"
    ],
    "ask": [
      "WebSearch",
      "Write",
      "Edit",
      "Bash"
    ]
  }
}
